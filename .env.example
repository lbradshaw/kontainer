# Kontainer Docker Environment Variables
# Copy this file to .env and customize as needed

# Server Port
# The port the web server will listen on inside the container
# Map to different host port using docker-compose ports configuration
PORT=3818

# Database Path
# Path inside the container where the database will be stored
# This should always be /data/kontainer.db when using Docker
DATABASE_PATH=/data/kontainer.db

# Theme
# Default UI theme: light or dark
THEME=light

# Advanced Configuration (Optional)
# These are not currently used but reserved for future use

# Log Level (future)
# LOG_LEVEL=info

# Max Upload Size (future)
# MAX_UPLOAD_SIZE=10MB

# Enable API Auth (future)
# ENABLE_AUTH=false
